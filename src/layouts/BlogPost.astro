---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} pubDate={pubDate} isArticle={true} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "datePublished": pubDate.toISOString(),
      ...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
      "author": {
        "@type": "Organization",
        "name": "Six Digits",
        "url": "https://sixdigits.ai"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Six Digits",
        "url": "https://sixdigits.ai"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `https://sixdigits.ai/blog/${title.toLowerCase().replace(/\s+/g, '-')}/`
      }
    })} />
    <style>
      .hero-image { display: none; }

      .post-layout {
        max-width: 720px;
        margin: 0 auto;
        padding: 3rem 1.5rem 5rem;
      }

      .post-header {
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--bg-border);
      }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.82rem;
        color: var(--text-muted);
        margin-bottom: 1.1rem;
        flex-wrap: wrap;
      }
      .post-meta .sep { opacity: 0.4; }

      .post-title {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(1.8rem, 3.5vw, 2.8rem);
        line-height: 1.15;
        letter-spacing: -0.02em;
        color: var(--text-primary);
        margin: 0 0 1rem;
      }

      .post-description {
        font-size: 1.05rem;
        color: var(--text-secondary);
        line-height: 1.65;
        margin: 0;
      }

      .last-updated {
        font-style: italic;
        font-size: 0.82rem;
        color: var(--text-muted);
        margin-top: 0.4rem;
      }

      /* Prose content */
      .prose {
        color: var(--text-primary);
        font-size: 1.05rem;
        line-height: 1.8;
      }
      .prose h2 {
        font-family: var(--font-body);
        font-size: 1.45rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 2.5rem 0 0.75rem;
        padding-top: 0.5rem;
      }
      .prose h3 {
        font-family: var(--font-body);
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 2rem 0 0.6rem;
      }
      .prose h4 {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-secondary);
        margin: 1.5rem 0 0.5rem;
      }
      .prose p { margin-bottom: 1.6em; }
      .prose a {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      .prose ul, .prose ol {
        padding-left: 1.4em;
        margin-bottom: 1.4em;
      }
      .prose li { margin-bottom: 0.4em; }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-secondary);
        text-decoration: none;
        margin-bottom: 2.5rem;
        transition: color 0.15s;
      }
      .back-link:hover { color: var(--accent); opacity: 1; }

      @media (max-width: 720px) {
        .post-layout { padding: 2rem 1rem 4rem; }
        .post-title { font-size: 1.7rem; }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <div class="post-layout">
        <a href="/blog" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
          </svg>
          Back to blog
        </a>

        <div class="hero-image">
          {heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
        </div>

        <header class="post-header">
          <div class="post-meta">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <>
                <span class="sep">·</span>
                <span class="last-updated">Updated <FormattedDate date={updatedDate} /></span>
              </>
            )}
          </div>
          <h1 class="post-title">{title}</h1>
          {description && <p class="post-description">{description}</p>}
        </header>

        <article class="prose">
          <slot />
        </article>
      </div>
    </main>
    <Footer />
  </body>
</html>
