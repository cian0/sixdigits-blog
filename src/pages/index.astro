---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts[0];
const bentoPosts = posts.slice(1, 4);   // up to 3 cards in bento grid
const listPosts  = posts.slice(0, 20);  // all posts for the list

function readTime(body: string | undefined): string {
  if (!body) return '5 min read';
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}

// Derive category from tags or fallback
function getCategory(post: (typeof posts)[0]): string {
  const tags = (post.data as any).tags;
  if (tags && tags.length > 0) return tags[0];
  const title = post.data.title.toLowerCase();
  if (title.includes('data') || title.includes('rag') || title.includes('pipeline')) return 'Data Engineering';
  if (title.includes('senior') || title.includes('career') || title.includes('job')) return 'Career';
  if (title.includes('ai') || title.includes('llm') || title.includes('model')) return 'AI Tools';
  if (title.includes('automat') || title.includes('agent')) return 'Automation';
  return 'AI';
}
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <!-- ════════════════════════════════════
         HERO
    ════════════════════════════════════ -->
    <section class="hero" aria-label="Hero">
      <div class="hero-grain" aria-hidden="true"></div>

      <div class="hero-inner">
        <div class="hero-eyebrow">
          <span class="live-dot" aria-hidden="true"></span>
          <span>Career · AI · Future of Tech</span>
        </div>

        <h1 class="hero-headline">
          Build a Career<br/>That <em>Compounds.</em>
        </h1>

        <p class="hero-sub">
          Practical strategy for tech professionals and new grads navigating the AI era — and building careers with real earning power.
        </p>

        <div class="hero-actions">
          <a href="/blog" class="btn-primary">Read the blog</a>
        </div>
      </div>

      <!-- Featured article card overlapping hero bottom -->
      {featured && (
        <div class="featured-wrap">
          <a href={`/blog/${featured.id}/`} class="featured-card reveal">
            <div class="featured-left">
              <div class="featured-meta">
                <span class="tag">Featured</span>
                <span class="meta-sep">·</span>
                <FormattedDate date={featured.data.pubDate} />
                <span class="meta-sep">·</span>
                <span>{readTime(featured.body)}</span>
              </div>
              <h2 class="featured-title">{featured.data.title}</h2>
              {featured.data.description && (
                <p class="featured-desc">{featured.data.description}</p>
              )}
            </div>
            <div class="featured-right" aria-hidden="true">
              <span class="featured-cta-arrow">→</span>
            </div>
          </a>
        </div>
      )}
    </section>

    <main>
      <!-- ════════════════════════════════════
           BENTO GRID (only if we have extra real posts)
      ════════════════════════════════════ -->
      {bentoPosts.length > 0 && (
        <section class="section bento-section" aria-label="Featured posts">
          <div class="section-header">
            <h2 class="section-title">Recent Stories</h2>
            <a href="/blog" class="section-link">All posts →</a>
          </div>

          <div class={`bento-grid bento-count-${Math.min(bentoPosts.length, 3)}`}>
            {bentoPosts.slice(0, 3).map((p, i) => (
              <a
                href={`/blog/${p.id}/`}
                class={`bento-card reveal ${i === 0 ? 'bento-large' : 'bento-small'}`}
                style={`animation-delay:${i * 80}ms`}
              >
                <div class="bento-body">
                  <span class="tag tag-sm">{getCategory(p)}</span>
                  <h3 class={`bento-title${i > 0 ? ' bento-title-sm' : ''}`}>{p.data.title}</h3>
                  {p.data.description && i === 0 && (
                    <p class="bento-desc">{p.data.description}</p>
                  )}
                </div>
                <div class="bento-footer">
                  <div class="author-row">
                    <div class="avatar" aria-hidden="true">S</div>
                    <span class="author-name">sixdigits.ai</span>
                  </div>
                  <span class="bento-meta"><FormattedDate date={p.data.pubDate} /> · {readTime(p.body)}</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- ════════════════════════════════════
           LATEST ARTICLES LIST
      ════════════════════════════════════ -->
      <section class="section articles-section" aria-label="Latest articles">
        <div class="section-header">
          <h2 class="section-title">Latest Articles</h2>
        </div>

        <ol class="articles-list">
          {listPosts.map((post, i) => (
            <li class="article-row reveal" style={`animation-delay:${i * 60}ms`}>
              <a href={`/blog/${post.id}/`} class="article-link">
                <span class="article-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <div class="article-body">
                  <div class="article-meta-row">
                    <span class="tag tag-xs">{getCategory(post)}</span>
                    <span class="article-date">
                      <FormattedDate date={post.data.pubDate} /> · {readTime(post.body)} read
                    </span>
                  </div>
                  <h3 class="article-title">{post.data.title}</h3>
                  {post.data.description && (
                    <p class="article-excerpt">{post.data.description}</p>
                  )}
                </div>
                <span class="article-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    </main>

    <Footer />
  </body>
</html>

<script>
  // ── Scroll reveal (IntersectionObserver) ────────────────────
  const revealEls = document.querySelectorAll('.reveal');
  const observer  = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  revealEls.forEach(el => observer.observe(el));
</script>

<style>
  /* ── Full-width layout override ── */
  :global(body) { overflow-x: hidden; }
  main {
    width: 100% !important;
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  /* ── Reveal animation ── */
  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }
  .reveal.revealed {
    opacity: 1;
    transform: none;
  }

  /* ════════════════════════════════════
     HERO
  ════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--bg-base);
    overflow: hidden;
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    background-size: 256px 256px;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent) 40%, transparent);
    opacity: 0.25;
  }

  .hero-inner {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 8rem 2rem 15rem;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.6rem;
  }
  .live-dot {
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
    animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3rem, 6vw, 7rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin: 0 0 1.25rem;
  }
  .hero-headline em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 52ch;
    margin: 0 0 2.25rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: var(--accent);
    color: #0f0f11;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.7em 1.45em;
    border-radius: 7px;
    text-decoration: none;
    transition: opacity 0.15s;
    min-height: 44px;
  }
  .btn-primary:hover { opacity: 0.85; color: #0f0f11; }

  /* ── Featured card ── */
  .featured-wrap {
    position: absolute;
    bottom: -2.5rem;
    padding: 0 2rem;
    display: flex;
    justify-content: flex-start;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 1200px;
  }

  .featured-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--bg-surface);
    border: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.10);
    border-radius: 14px;
    padding: 1.75rem 2rem;
    text-decoration: none;
    max-width: 900px;
    width: 100%;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .featured-card:hover {
    border-color: oklch(from var(--text-primary, #e8e8e0) l c h / 0.22);
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
    opacity: 1;
  }

  .featured-left { flex: 1; min-width: 0; }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.7rem;
    flex-wrap: wrap;
  }
  .meta-sep { opacity: 0.35; }

  .featured-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    line-height: 1.22;
    color: var(--text-primary);
    margin: 0 0 0.55rem;
  }

  .featured-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-right { flex-shrink: 0; }
  .featured-cta-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.12);
    color: var(--accent);
    font-size: 1rem;
    transition: background 0.15s, transform 0.15s;
  }
  .featured-card:hover .featured-cta-arrow {
    background: var(--accent-dim);
    transform: translateX(2px);
  }

  /* ════════════════════════════════════
     SHARED SECTION CHROME
  ════════════════════════════════════ */
  .section {
    padding: 5rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }
  .section-title {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0;
  }
  .section-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
  }
  .section-link:hover { opacity: 0.8; }

  /* ── Tags ── */
  .tag {
    display: inline-block;
    background: var(--accent-dim);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2em 0.7em;
    border-radius: 4px;
  }
  .tag-sm { font-size: 0.68rem; }
  .tag-xs { font-size: 0.65rem; padding: 0.15em 0.55em; }

  /* ════════════════════════════════════
     BENTO GRID
  ════════════════════════════════════ */
  .bento-section {
    padding-top: 6.5rem;
  }

  .bento-grid {
    display: grid;
    gap: 1rem;
  }
  /* 1 post → full width */
  .bento-count-1 { grid-template-columns: 1fr; }
  /* 2 posts → side by side */
  .bento-count-2 { grid-template-columns: 2fr 1fr; }
  /* 3 posts → large + stack */
  .bento-count-3 { grid-template-columns: 2fr 1fr; }

  .bento-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--bg-surface);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3), 0 0 0 1px oklch(from var(--text-primary, #e8e8e0) l c h / 0.08);
    transition: box-shadow 0.2s, transform 0.2s;
    min-height: 200px;
  }
  .bento-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px oklch(from var(--text-primary, #e8e8e0) l c h / 0.18);
    transform: translateY(-2px);
    opacity: 1;
  }

  /* In a 2 or 3-col grid, first card spans left, rest stack right */
  .bento-count-2 .bento-large,
  .bento-count-3 .bento-large { grid-column: 1; }
  .bento-count-2 .bento-small,
  .bento-count-3 .bento-small { grid-column: 2; }

  .bento-body { flex: 1; }
  .bento-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.2rem;
    line-height: 1.3;
    color: var(--text-primary);
    margin: 0.5rem 0 0.4rem;
  }
  .bento-title-sm { font-size: 1rem; }
  .bento-desc {
    font-size: 0.84rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bento-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .author-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .avatar {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--accent-dim);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .author-name { font-size: 0.78rem; color: var(--text-secondary); font-weight: 500; }
  .bento-meta { font-size: 0.76rem; color: var(--text-muted); }

  /* ════════════════════════════════════
     ARTICLES LIST
  ════════════════════════════════════ */
  .articles-section {
    padding-top: 0;
    border-top: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.08);
  }

  .articles-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article-row {
    border-bottom: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.07);
  }
  .article-row:first-child { border-top: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.07); }

  .article-link {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .article-link:hover .article-title { color: var(--accent); }
  .article-link:hover .article-arrow { color: var(--accent); transform: translateX(4px); }
  .article-link:hover { opacity: 1; }
  .article-row:nth-child(even) .article-link:hover { background: oklch(from var(--text-primary, #e8e8e0) l c h / 0.02); }

  .article-num {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    opacity: 0.4;
    flex-shrink: 0;
    padding-top: 0.15em;
    min-width: 2ch;
    font-variant-numeric: tabular-nums;
  }

  .article-body { flex: 1; min-width: 0; }

  .article-meta-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }
  .article-date { font-size: 0.78rem; color: var(--text-muted); }

  .article-title {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.35rem;
    line-height: 1.35;
    transition: color 0.15s;
  }

  .article-excerpt {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-arrow {
    font-size: 1rem;
    color: var(--text-muted);
    flex-shrink: 0;
    padding-top: 0.2em;
    transition: color 0.15s, transform 0.15s;
  }

  /* ════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════ */
  @media (max-width: 900px) {
    .bento-count-2,
    .bento-count-3 { grid-template-columns: 1fr; }
    .bento-count-2 .bento-small,
    .bento-count-3 .bento-small { grid-column: 1; }
  }

  @media (max-width: 640px) {
    .hero-inner { padding: 6rem 1rem 17rem; }
    .featured-wrap { padding: 0 1rem; }
    .featured-card { padding: 1.25rem; flex-direction: column; }
    .featured-right { display: none; }
    .bento-section { padding-top: 8rem; }
    .section { padding: 3rem 1rem; }
    .article-link { gap: 0.75rem; }
    .article-num { display: none; }
  }
</style>
