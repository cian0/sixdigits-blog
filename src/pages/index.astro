---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts[0];
const bentoExtra = posts.slice(1, 4);
const listPosts  = posts.slice(0, 6);

function readTime(body: string | undefined): string {
  if (!body) return '5 min read';
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}

// Dummy bento cards to fill grid if not enough real posts
const dummyBento = [
  {
    id: null,
    title: 'How AI Agents Are Replacing the Junior Dev Workflow',
    description: 'Agentic loops, tool-use, and the new reality of software delivery — what it means when your IDE can ship a PR unattended.',
    pubDate: new Date('2026-03-18'),
    category: 'AI Tools',
    readTime: '7 min read',
  },
  {
    id: null,
    title: 'The Prompt Engineer Is Already Obsolete',
    description: 'Why the hottest job title of 2023 is fading, and what actually matters in a world of frontier models.',
    pubDate: new Date('2026-03-10'),
    category: 'Opinion',
    readTime: '5 min read',
  },
  {
    id: null,
    title: 'Data Engineering in the Age of LLM Pipelines',
    description: 'Embedding stores, vector DBs, and the new data stack emerging around retrieval-augmented generation.',
    pubDate: new Date('2026-02-28'),
    category: 'Data Engineering',
    readTime: '9 min read',
  },
];

// Dummy list articles
const dummyList = [
  {
    category: 'Career',
    title: 'Senior Engineers Are Thriving — Here\'s Exactly Why',
    excerpt: 'The AI wave isn\'t flattening the org chart; it\'s amplifying the gap between those who can architect systems and those who cannot.',
    date: 'Mar 24, 2026',
    readTime: '6 min',
  },
  {
    category: 'Automation',
    title: 'GitHub Copilot Workspace: A Week in the Trenches',
    excerpt: 'We ran a real-world sprint with Copilot Workspace as the primary implementation tool. Here\'s what broke, what shipped, and what surprised us.',
    date: 'Mar 20, 2026',
    readTime: '8 min',
  },
  {
    category: 'AI Tools',
    title: 'Claude 3.5 vs GPT-4o for Code Review: A Practical Benchmark',
    excerpt: 'We threw 200 real PRs at both models. The results were more nuanced than the leaderboard suggests.',
    date: 'Mar 15, 2026',
    readTime: '10 min',
  },
  {
    category: 'Data Engineering',
    title: 'Why Your RAG Pipeline Is Lying to You',
    excerpt: 'Retrieval-augmented generation sounds bulletproof in theory. In production, subtle chunking and embedding errors silently degrade answer quality.',
    date: 'Mar 10, 2026',
    readTime: '7 min',
  },
  {
    category: 'Opinion',
    title: 'The 10x Engineer Myth Was Always Wrong. Now It\'s Dangerous.',
    excerpt: 'When AI tools can triple output overnight, glorifying raw individual productivity misses the actual leverage point: judgment.',
    date: 'Mar 5, 2026',
    readTime: '5 min',
  },
  {
    category: 'Career',
    title: 'How to Negotiate Your Salary in an AI-Saturated Job Market',
    excerpt: 'Hiring is slower, but compensation for senior talent is rising. Here\'s how to position and negotiate when you\'re competing against AI-augmented peers.',
    date: 'Feb 28, 2026',
    readTime: '6 min',
  },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <!-- ════════════════════════════════════
         HERO
    ════════════════════════════════════ -->
    <section class="hero" aria-label="Hero">
      <div class="hero-grain" aria-hidden="true"></div>

      <div class="hero-inner">
        <div class="hero-eyebrow">
          <span class="live-dot" aria-hidden="true"></span>
          <span>AI · Automation · Future of Work</span>
        </div>

        <h1 class="hero-headline">
          The Intelligence<br/><em>Brief.</em>
        </h1>

        <p class="hero-sub">
          Dispatches from the frontier of AI, automation, and the future of work.
        </p>

        <div class="hero-actions">
          <a href="/blog" class="btn-primary">Read the blog</a>
          <a href="/rss.xml" class="btn-ghost">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/>
              <circle cx="5" cy="19" r="1" fill="currentColor" stroke="none"/>
            </svg>
            RSS
          </a>
        </div>
      </div>

      <!-- Featured article card overlapping hero bottom -->
      {featured && (
        <div class="featured-wrap">
          <a href={`/blog/${featured.id}/`} class="featured-card reveal">
            <div class="featured-left">
              <div class="featured-meta">
                <span class="tag">Featured</span>
                <span class="meta-sep">·</span>
                <FormattedDate date={featured.data.pubDate} />
                <span class="meta-sep">·</span>
                <span>{readTime(featured.body)}</span>
              </div>
              <h2 class="featured-title">{featured.data.title}</h2>
              {featured.data.description && (
                <p class="featured-desc">{featured.data.description}</p>
              )}
            </div>
            <div class="featured-right" aria-hidden="true">
              <span class="featured-cta-arrow">→</span>
            </div>
          </a>
        </div>
      )}
    </section>

    <main>
      <!-- ════════════════════════════════════
           BENTO GRID
      ════════════════════════════════════ -->
      <section class="section bento-section" aria-label="Featured posts">
        <div class="section-header">
          <h2 class="section-title">Recent Stories</h2>
          <a href="/blog" class="section-link">All posts →</a>
        </div>

        <div class="bento-grid">
          <!-- Large card (real first extra post or dummy) -->
          {(() => {
            const p = bentoExtra[0];
            const d = dummyBento[0];
            const href = p ? `/blog/${p.id}/` : '#';
            const title = p ? p.data.title : d.title;
            const desc  = p ? (p.data.description || d.description) : d.description;
            const date  = p ? p.data.pubDate : d.pubDate;
            const rt    = p ? readTime(p.body) : d.readTime;
            const cat   = d.category;
            return (
              <a href={href} class="bento-card bento-large reveal">
                <div class="bento-body">
                  <span class="tag tag-sm">{cat}</span>
                  <h3 class="bento-title">{title}</h3>
                  <p class="bento-desc">{desc}</p>
                </div>
                <div class="bento-footer">
                  <div class="author-row">
                    <div class="avatar" aria-hidden="true">S</div>
                    <span class="author-name">sixdigits.ai</span>
                  </div>
                  <span class="bento-meta"><FormattedDate date={date} /> · {rt}</span>
                </div>
              </a>
            );
          })()}

          <!-- Two stacked small cards -->
          <div class="bento-stack">
            {[1, 2].map(i => {
              const p = bentoExtra[i];
              const d = dummyBento[i];
              const href  = p ? `/blog/${p.id}/` : '#';
              const title = p ? p.data.title : d.title;
              const desc  = p ? (p.data.description || d.description) : d.description;
              const date  = p ? p.data.pubDate : d.pubDate;
              const rt    = p ? readTime(p.body) : d.readTime;
              const cat   = d.category;
              return (
                <a href={href} class="bento-card bento-small reveal" style={`animation-delay:${i * 80}ms`}>
                  <div class="bento-body">
                    <span class="tag tag-sm">{cat}</span>
                    <h3 class="bento-title bento-title-sm">{title}</h3>
                  </div>
                  <div class="bento-footer">
                    <div class="author-row">
                      <div class="avatar avatar-xs" aria-hidden="true">S</div>
                      <span class="author-name">{rt}</span>
                    </div>
                    <span class="bento-meta"><FormattedDate date={date} /></span>
                  </div>
                </a>
              );
            })}
          </div>

          <!-- Full-width horizontal card -->
          {(() => {
            const d = dummyBento[2];
            return (
              <a href="/blog" class="bento-card bento-full reveal">
                <div class="bento-full-inner">
                  <div>
                    <span class="tag tag-sm">{d.category}</span>
                    <h3 class="bento-title">{d.title}</h3>
                    <p class="bento-desc">{d.description}</p>
                  </div>
                  <div class="bento-full-right">
                    <div class="author-row">
                      <div class="avatar" aria-hidden="true">S</div>
                      <div>
                        <div class="author-name">sixdigits.ai</div>
                        <div class="bento-meta">{d.readTime}</div>
                      </div>
                    </div>
                    <span class="bento-arrow">→</span>
                  </div>
                </div>
              </a>
            );
          })()}
        </div>
      </section>

      <!-- ════════════════════════════════════
           TOPICS STRIP
      ════════════════════════════════════ -->
      <section class="section topics-section" aria-label="Topics">
        <div class="topics-outer">
          <div class="topics-fade-left" aria-hidden="true"></div>
          <div class="topics-scroll" role="list">
            {['All', 'AI Tools', 'Automation', 'Data Engineering', 'Career', 'Opinion'].map((t, i) => (
              <button
                class={`topic-pill${i === 0 ? ' active' : ''}`}
                role="listitem"
                data-topic={t}
                type="button"
              >{t}</button>
            ))}
          </div>
          <div class="topics-fade-right" aria-hidden="true"></div>
        </div>
      </section>

      <!-- ════════════════════════════════════
           LATEST ARTICLES LIST
      ════════════════════════════════════ -->
      <section class="section articles-section" aria-label="Latest articles">
        <div class="section-header">
          <h2 class="section-title">Latest Articles</h2>
        </div>

        <ol class="articles-list">
          {dummyList.map((art, i) => (
            <li class="article-row reveal" style={`animation-delay:${i * 60}ms`}>
              <a href="/blog" class="article-link">
                <span class="article-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <div class="article-body">
                  <div class="article-meta-row">
                    <span class="tag tag-xs">{art.category}</span>
                    <span class="article-date">{art.date} · {art.readTime} read</span>
                  </div>
                  <h3 class="article-title">{art.title}</h3>
                  <p class="article-excerpt">{art.excerpt}</p>
                </div>
                <span class="article-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ol>

        <!-- Real posts if available -->
        {listPosts.length > 0 && (
          <div class="real-posts-divider">
            <span>From the blog</span>
          </div>
        )}
        {listPosts.map((post, i) => (
          <ol class="articles-list" start={dummyList.length + 1 + i}>
            <li class="article-row reveal" style={`animation-delay:${i * 60}ms`}>
              <a href={`/blog/${post.id}/`} class="article-link">
                <span class="article-num" aria-hidden="true">{String(dummyList.length + 1 + i).padStart(2, '0')}</span>
                <div class="article-body">
                  <div class="article-meta-row">
                    <span class="tag tag-xs">AI</span>
                    <span class="article-date"><FormattedDate date={post.data.pubDate} /> · {readTime(post.body)} read</span>
                  </div>
                  <h3 class="article-title">{post.data.title}</h3>
                  {post.data.description && <p class="article-excerpt">{post.data.description}</p>}
                </div>
                <span class="article-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          </ol>
        ))}

        <div class="load-more-wrap">
          <button class="btn-load-more" type="button">Load more articles</button>
        </div>
      </section>

      <!-- ════════════════════════════════════
           NEWSLETTER CTA
      ════════════════════════════════════ -->
      <section class="section newsletter-section reveal" aria-label="Newsletter">
        <div class="newsletter-inner">
          <div class="newsletter-text">
            <span class="nl-eyebrow">Newsletter</span>
            <h2 class="nl-headline">Stay ahead of the curve.</h2>
            <p class="nl-proof">Join 12,000+ readers. No spam. Unsubscribe anytime.</p>
          </div>
          <form class="nl-form" onsubmit="return false;" aria-label="Subscribe to newsletter">
            <input
              type="email"
              class="nl-input"
              placeholder="your@email.com"
              required
              aria-label="Email address"
            />
            <button type="submit" class="nl-btn">Subscribe</button>
          </form>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<script>
  // ── Topic pills ──────────────────────────────────────────────
  document.querySelectorAll('.topic-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.topic-pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  // ── Scroll reveal (IntersectionObserver) ────────────────────
  const revealEls = document.querySelectorAll('.reveal');
  const observer  = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, idx) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  revealEls.forEach(el => observer.observe(el));
</script>

<style>
  /* ── Full-width layout override ── */
  :global(body) { overflow-x: hidden; }
  main {
    width: 100% !important;
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  /* ── Reveal animation ── */
  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }
  .reveal.revealed {
    opacity: 1;
    transform: none;
  }

  /* ════════════════════════════════════
     HERO
  ════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--bg-base);
    overflow: hidden;
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    background-size: 256px 256px;
  }

  /* No gradient blobs — just a single thin teal rule at bottom */
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent) 40%, transparent);
    opacity: 0.25;
  }

  .hero-inner {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 8rem 2rem 15rem;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.6rem;
  }
  .live-dot {
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
    animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3rem, 6vw, 7rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin: 0 0 1.25rem;
  }
  .hero-headline em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 52ch;
    margin: 0 0 2.25rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: var(--accent);
    color: #0f0f11;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.7em 1.45em;
    border-radius: 7px;
    text-decoration: none;
    transition: opacity 0.15s;
    min-height: 44px;
  }
  .btn-primary:hover { opacity: 0.85; color: #0f0f11; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.7em 1.1em;
    border-radius: 7px;
    border: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.10);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
    min-height: 44px;
  }
  .btn-ghost:hover { color: var(--text-primary); border-color: oklch(from var(--text-primary, #e8e8e0) l c h / 0.22); opacity: 1; }

  /* ── Featured card ── */
  .featured-wrap {
    position: absolute;
    bottom: -2.5rem;
    left: 0; right: 0;
    padding: 0 2rem;
    display: flex;
    justify-content: flex-start;
    max-width: 1200px;
    margin: 0 auto;
    /* center absolute trick */
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
  }

  .featured-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--bg-surface);
    border: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.10);
    border-radius: 14px;
    padding: 1.75rem 2rem;
    text-decoration: none;
    max-width: 900px;
    width: 100%;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .featured-card:hover {
    border-color: oklch(from var(--text-primary, #e8e8e0) l c h / 0.22);
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
    opacity: 1;
  }

  .featured-left { flex: 1; min-width: 0; }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.7rem;
    flex-wrap: wrap;
  }
  .meta-sep { opacity: 0.35; }

  .featured-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    line-height: 1.22;
    color: var(--text-primary);
    margin: 0 0 0.55rem;
  }

  .featured-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-right {
    flex-shrink: 0;
  }
  .featured-cta-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.12);
    color: var(--accent);
    font-size: 1rem;
    transition: background 0.15s, transform 0.15s;
  }
  .featured-card:hover .featured-cta-arrow {
    background: var(--accent-dim);
    transform: translateX(2px);
  }

  /* ════════════════════════════════════
     SHARED SECTION CHROME
  ════════════════════════════════════ */
  .section {
    padding: 5rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }
  .section-title {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0;
  }
  .section-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
  }
  .section-link:hover { opacity: 0.8; }

  /* ── Tags ── */
  .tag {
    display: inline-block;
    background: var(--accent-dim);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2em 0.7em;
    border-radius: 4px;
  }
  .tag-sm { font-size: 0.68rem; }
  .tag-xs { font-size: 0.65rem; padding: 0.15em 0.55em; }

  /* ════════════════════════════════════
     BENTO GRID
  ════════════════════════════════════ */
  .bento-section {
    padding-top: 6.5rem; /* clear the overlapping featured card */
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: auto auto;
    gap: 1rem;
  }

  .bento-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--bg-surface);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    /* shadow not border for elevation */
    box-shadow: 0 2px 8px rgba(0,0,0,0.3), 0 0 0 1px oklch(from var(--text-primary, #e8e8e0) l c h / 0.08);
    transition: box-shadow 0.2s, transform 0.2s;
    min-height: 220px;
  }
  .bento-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px oklch(from var(--text-primary, #e8e8e0) l c h / 0.18);
    transform: translateY(-2px);
    opacity: 1;
  }

  .bento-large { grid-column: 1; grid-row: 1; }
  .bento-stack { grid-column: 2; grid-row: 1; display: flex; flex-direction: column; gap: 1rem; }
  .bento-small { min-height: 160px; }
  .bento-full  { grid-column: 1 / -1; grid-row: 2; min-height: 140px; }

  .bento-body { flex: 1; }
  .bento-title {
    font-family: var(--font-display);
    font-weight: 400;
