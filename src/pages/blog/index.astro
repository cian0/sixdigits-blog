---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function readTime(body: string | undefined): string {
  if (!body) return '5 min read';
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}

function getCategory(post: (typeof posts)[0]): string {
  const tags = (post.data as any).tags;
  if (tags && tags.length > 0) return tags[0];
  const title = post.data.title.toLowerCase();
  if (title.includes('data') || title.includes('rag') || title.includes('pipeline')) return 'Data Engineering';
  if (title.includes('senior') || title.includes('career') || title.includes('job')) return 'Career';
  if (title.includes('ai') || title.includes('llm') || title.includes('model')) return 'AI Tools';
  if (title.includes('automat') || title.includes('agent')) return 'Automation';
  return 'AI';
}

// Collect unique categories from real posts for the filter strip
const allCategories = ['All', ...Array.from(new Set(posts.map(p => getCategory(p))))];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>
      <!-- ── Page Header ── -->
      <div class="page-header">
        <div class="page-header-inner">
          <div class="page-eyebrow">
            <span class="live-dot" aria-hidden="true"></span>
            <span>All Articles</span>
          </div>
          <h1 class="page-title">Six Digits</h1>
          <p class="page-sub">Practical strategy for tech professionals and new grads navigating the AI era — building careers with real earning power.</p>
        </div>
      </div>

      <!-- ── Topics filter strip ── -->
      {allCategories.length > 1 && (
        <div class="topics-bar">
          <div class="topics-bar-inner">
            <div class="topics-fade-left" aria-hidden="true"></div>
            <div class="topics-scroll" role="list">
              {allCategories.map((t, i) => (
                <button
                  class={`topic-pill${i === 0 ? ' active' : ''}`}
                  role="listitem"
                  data-topic={t}
                  type="button"
                >{t}</button>
              ))}
            </div>
            <div class="topics-fade-right" aria-hidden="true"></div>
          </div>
        </div>
      )}

      <!-- ── Articles ── -->
      <section class="articles-section" aria-label="Blog posts">
        <div class="articles-inner">
          {posts.length === 0 ? (
            <p class="empty-state">No posts yet. Check back soon.</p>
          ) : (
            <ol class="articles-list">
              {posts.map((post, i) => (
                <li
                  class="article-row reveal"
                  data-category={getCategory(post)}
                  style={`animation-delay:${i * 60}ms`}
                >
                  <a href={`/blog/${post.id}/`} class="article-link">
                    <span class="article-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                    <div class="article-body">
                      <div class="article-meta-row">
                        <span class="tag tag-xs">{getCategory(post)}</span>
                        <span class="article-date">
                          <FormattedDate date={post.data.pubDate} />
                          &nbsp;·&nbsp;{readTime(post.body)}
                        </span>
                      </div>
                      <h2 class="article-title">{post.data.title}</h2>
                      {post.data.description && (
                        <p class="article-excerpt">{post.data.description}</p>
                      )}
                    </div>
                    <span class="article-arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ol>
          )}
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<script>
  // ── Category filter ───────────────────────────────
  const pills = document.querySelectorAll<HTMLButtonElement>('.topic-pill');
  const rows  = document.querySelectorAll<HTMLLIElement>('.article-row');

  pills.forEach(btn => {
    btn.addEventListener('click', () => {
      pills.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const topic = btn.dataset.topic ?? 'All';
      rows.forEach(row => {
        if (topic === 'All' || row.dataset.category === topic) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });
  });

  // ── Scroll reveal ─────────────────────────────────
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('revealed'); observer.unobserve(e.target); }
    }),
    { threshold: 0.08 }
  );
  revealEls.forEach(el => observer.observe(el));
</script>

<style>
  :global(body) { overflow-x: hidden; }
  main {
    width: 100% !important;
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  /* Reveal */
  .reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.4s ease, transform 0.4s ease; }
  .reveal.revealed { opacity: 1; transform: none; }

  /* ── Page Header ── */
  .page-header {
    background: var(--bg-base);
    padding: 5rem 2rem 3rem;
    border-bottom: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.08);
  }
  .page-header-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .live-dot {
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.25} }

  .page-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 0.6rem;
  }
  .page-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    margin: 0;
    max-width: 54ch;
    line-height: 1.6;
  }

  /* ── Topics strip ── */
  .topics-bar {
    background: var(--bg-base);
    padding: 1rem 2rem;
    border-bottom: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.07);
    position: sticky;
    top: 64px;
    z-index: 50;
    backdrop-filter: blur(8px);
  }
  .topics-bar-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }
  .topics-scroll {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0.1rem 0;
  }
  .topics-scroll::-webkit-scrollbar { display: none; }

  .topics-fade-left, .topics-fade-right {
    position: absolute; top: 0; bottom: 0; width: 2.5rem;
    pointer-events: none; z-index: 1;
  }
  .topics-fade-left  { left: 0;  background: linear-gradient(to right, var(--bg-base), transparent); }
  .topics-fade-right { right: 0; background: linear-gradient(to left,  var(--bg-base), transparent); }

  .topic-pill {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.4em 1em;
    border-radius: 999px;
    border: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.12);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    min-height: 36px;
    font-family: var(--font-body);
  }
  .topic-pill:hover { border-color: oklch(from var(--text-primary, #e8e8e0) l c h / 0.22); color: var(--text-primary); }
  .topic-pill.active { background: var(--accent); color: #0f0f11; border-color: var(--accent); font-weight: 600; }

  /* ── Articles Section ── */
  .articles-section {
    padding: 3rem 2rem;
  }
  .articles-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .empty-state {
    color: var(--text-muted);
    font-size: 1rem;
    padding: 3rem 0;
    text-align: center;
  }

  .articles-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article-row {
    border-bottom: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.07);
  }
  .article-row:first-child { border-top: 1px solid oklch(from var(--text-primary, #e8e8e0) l c h / 0.07); }

  .article-link {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.4rem 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }
  .article-link:hover { opacity: 1; }
  .article-link:hover .article-title { color: var(--accent); }
  .article-link:hover .article-arrow { color: var(--accent); transform: translateX(4px); }
  .article-row:nth-child(even) .article-link:hover { background: oklch(from var(--text-primary, #e8e8e0) l c h / 0.015); }

  .article-num {
    font-size: 0.74rem;
    font-weight: 500;
    color: var(--text-muted);
    opacity: 0.35;
    flex-shrink: 0;
    padding-top: 0.15em;
    min-width: 2ch;
    font-variant-numeric: tabular-nums;
  }

  .article-body { flex: 1; min-width: 0; }

  .article-meta-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }
  .article-date { font-size: 0.78rem; color: var(--text-muted); }

  .article-title {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.35rem;
    line-height: 1.35;
    transition: color 0.15s;
  }

  .article-excerpt {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-arrow {
    font-size: 1rem;
    color: var(--text-muted);
    flex-shrink: 0;
    padding-top: 0.2em;
    transition: color 0.15s, transform 0.15s;
  }

  /* Tags */
  .tag { display: inline-block; background: var(--accent-dim); color: var(--accent); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.2em 0.7em; border-radius: 4px; }
  .tag-xs { font-size: 0.65rem; padding: 0.15em 0.55em; }

  /* Responsive */
  @media (max-width: 640px) {
    .page-header { padding: 3.5rem 1rem 2rem; }
    .topics-bar { padding: 0.75rem 1rem; }
    .articles-section { padding: 2rem 1rem; }
    .article-link { gap: 0.75rem; }
    .article-num { display: none; }
  }
</style>
