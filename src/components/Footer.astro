<style>
  footer {
    background: var(--bg-surface);
    border-top: 1px solid var(--bg-border);
    padding: 4rem 1.5rem 2rem;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 4rem;
    flex-wrap: wrap;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--bg-border);
  }

  /* Brand */
  .footer-brand {
    flex: 1;
    min-width: 240px;
  }
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    margin-bottom: 0.75rem;
  }
  .footer-wordmark {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }
  .footer-tagline {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 280px;
    margin: 0 0 1.25rem;
  }
  .social-links {
    display: flex;
    gap: 0.75rem;
  }
  .social-links a {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    transition: color 0.15s;
    text-decoration: none;
  }
  .social-links a:hover { color: var(--accent); opacity: 1; }

  /* Link columns */
  .footer-links-group {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 120px;
  }
  .footer-col-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 0.25rem;
    font-family: var(--font-body);
  }
  .footer-col a {
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: var(--text-primary); opacity: 1; }

  /* Bottom bar */
  .footer-bottom {
    max-width: 1200px;
    margin: 1.5rem auto 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-muted);
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .footer-bottom a {
    color: var(--text-secondary);
    text-decoration: none;
  }
  .footer-bottom a:hover { color: var(--accent); opacity: 1; }

  @media (max-width: 640px) {
    .footer-inner { gap: 2.5rem; }
    .footer-bottom { flex-direction: column; text-align: center; }
  }
</style>
